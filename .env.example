# ─── ECHverse Devoid Stack — Environment Variables ───────────────────────────
# Copy this file to .env and fill in real values before running in production.

# GCP Project
PROJECT_ID=ellis-clearing-house

# Emulator hosts (used in local/dev; override for production)
PUBSUB_EMULATOR_HOST=pubsub-emulator:8085
SPANNER_EMULATOR_HOST=spanner-emulator:9010

# Node environment
NODE_ENV=development

# Apple Pay / KMS
KMS_EMULATOR_MODE=true
PUBSUB_TOPIC=state-events

# Visa Direct (Chime relayer)
VISA_DIRECT_API_URL=https://sandbox.api.visa.com/visadirect/v1/pullfundstransactions
VISA_CERT_PATH=/etc/ssl/certs/visa-dev.pem

# NCSECU ACH Engine
ACH_ROUTING_TARGET=253177049
SEC_CODES_SUPPORTED=PPD,WEB,CCD
GCS_BUCKET_NAME=ech-nacha-staging-local
